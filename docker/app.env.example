# ==============================
# Application secrets and basics
# ==============================
# Secret for Flask session cookies (change in production).
SECRET_KEY=change-me

# Referral code required at signup. If set, a matching code grants immediate access
# (is_verified + is_approved). Leave empty to use email verification instead.
SIGNUP_REFERRAL_CODE=

# Where the app writes uploaded files before handing to object storage.
UPLOAD_FOLDER=static/uploads

# Comma-separated list of allowed file extensions for uploads.
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,mp3,mp4

# ==================================
# Storage selection (adapter routing)
# ==================================
# Global default for question/user/media stores.
STORE_BACKEND=postgres

# Per-store overrides (optional).
QUESTION_STORE=postgres
USER_STORE=postgres
MEDIA_STORE=minio

# ===================
# Postgres connection
# ===================
# Optional DSN that overrides the host/port/db/user/password settings below.
POSTGRES_DSN=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trivia
POSTGRES_USER=trivia
POSTGRES_PASSWORD=trivia

# Auto-create tables on app startup (dev only; use Alembic in production).
POSTGRES_AUTO_CREATE=0

# ==============================
# MinIO (S3-compatible) settings
# ==============================
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=trivia
MINIO_SECRET_KEY=trivia-secret
MINIO_BUCKET=trivia-media
MINIO_REGION=us-east-1
MINIO_SECURE=0
MINIO_AUTO_CREATE_BUCKET=1

# Media delivery behavior
MEDIA_PROXY=1
MEDIA_URL_EXPIRES_SECONDS=3600

# ====================================
# Legacy AWS adapters (optional / AWS)
# ====================================
AWS_REGION=eu-central-1
AWS_ENDPOINT_URL=
DYNAMODB_TABLE=TriviaQuestions
USERS_TABLE=TriviaUsersDev
AWS_S3_BUCKET=chris-trivia-media-bucket

# Optional AWS credentials (only if using AWS adapters)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

# =================
# Caddy (reverse proxy)
# =================
CADDY_DOMAIN=localhost
CADDY_EMAIL=
